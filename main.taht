# Ayarlar
Game Settings (settings:main)
	description: "Osmanlı saray yönetim oyunu"
	game_over_on_zero: "Devlet çöktü!"
	game_over_on_max: "Saltanat sona erdi!"
	starting_flags: flag:start

# Ana kaynaklar
Hazine (counter:hazine, killer)
	start: 60

Ordu (counter:ordu, killer)
	start: 50

Reaya (counter:reaya, killer)
	start: 50

Din (counter:din, killer)
	start: 50

Dilek Hakkı (counter:dilek)
	start: 0

Kudret-i Şahane (counter:kudret)
	start: 50

Sultanlar (counter:sultanlar, keep)
	start: 0

Sehzade (counter:sehzade, keep)
	start: 0

# İmar sayaçları
Cami (counter:cami, keep)
	start: 0

Türbe (counter:turbe, keep)
	start: 0

Mesire Yeri (counter:mesire, keep)
	start: 0

Harem Ziyaret (counter:haremziyaret)
	start: 0

# Virtual counter: toplam imar
İmar (counter:toplam_imar)
	source: counter:cami, counter:turbe, counter:mesire
	aggregate: sum

# Yaş
Yaşın (counter:yas)
	start: 18

